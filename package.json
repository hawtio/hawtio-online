{
  "name": "@hawtio/online-root",
  "version": "0.0.0",
  "private": true,
  "description": "Containerized version of hawtio for kubernetes",
  "author": "Hawtio developer team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hawtio/hawtio-online.git"
  },
  "scripts": {
    "build": "pnpm build:online && pnpm license",
    "start:online": "pnpm build:mgmt && pnpm start:shell",
    "analyze:online": "pnpm build:online && pnpm analyze:shell",
    "build:online": "pnpm workspaces foreach -v -Aipt --exclude @hawtio/online-root --exclude \"@hawtio/*-app\" run build",
    "start:shell": "pnpm workspace @hawtio/online-shell start",
    "analyze:shell": "pnpm workspace @hawtio/online-shell analyze:webpack:prod",
    "build:shell": "pnpm workspace @hawtio/online-shell build",
    "start:mgmt": "pnpm build:mgmt && pnpm start:mgmtApp",
    "build:mgmt": "pnpm build:k8s && pnpm build:mgmtApi",
    "start:mgmtApp": "pnpm workspace @hawtio/online-management-api-app start",
    "build:mgmtApi": "pnpm workspace @hawtio/online-management-api build",
    "start:k8s": "pnpm build:k8s && pnpm start:k8sApp",
    "analyze:k8s": "pnpm build:k8s && pnpm analyze:k8sApp",
    "build:k8s": "pnpm build:oAuthApi && pnpm build:k8sApi",
    "start:k8sApp": "pnpm workspace @hawtio/online-kubernetes-api-app start",
    "analyze:k8sApp": "pnpm workspace @hawtio/online-kubernetes-api-app analyze",
    "build:k8sApi": "pnpm workspace @hawtio/online-kubernetes-api build",
    "start:oAuth": "pnpm build:oAuthApi && pnpm start:oAuthApp",
    "start:oAuthApp": "pnpm workspace @hawtio/online-oauth-app start",
    "build:oAuthApi": "pnpm workspace @hawtio/online-oauth build",
    "start:gateway": "pnpm workspace @hawtio/gateway start:gateway-server",
    "build:gateway": "pnpm workspace @hawtio/gateway build",
    "lint": "pnpm eslint packages/ docker/gateway/",
    "lint:fix": "pnpm eslint packages/  docker/gateway/ --fix",
    "format:check": "pnpm prettier --check packages/  docker/gateway/",
    "format:fix": "pnpm prettier --write packages/  docker/gateway/",
    "image": "docker build -t quay.io/${ORG:-hawtio}/${PROJECT:-online}:${TAG:-latest} -f Dockerfile-nginx .",
    "image:gateway": "docker build -t quay.io/${ORG:-hawtio}/${PROJECT:-online-gateway}:${TAG:-latest} -f Dockerfile-gateway .",
    "license": "mkdir -p docker/licenses && pnpm licenses generate-disclaimer -R > docker/licenses/licenses.txt",
    "gen:proxying": "./scripts/generate-proxying.sh",
    "gen:serving": "./scripts/generate-serving.sh",
    "test": "pnpm workspaces foreach -v -Aipt --exclude @hawtio/online-root --exclude \"@hawtio/*-app\" run test",
    "test:watch": "pnpm workspaces foreach -v -Aipt --exclude @hawtio/online-root --exclude \"@hawtio/*-app\" run test:watch",
    "deploy:k8s:namespace": "./scripts/kube-apply.sh deploy/k8s/namespace/",
    "deploy:k8s:cluster": "./scripts/kube-apply.sh deploy/k8s/cluster/",
    "deploy:openshift:namespace": "./scripts/kube-apply.sh deploy/openshift/namespace/",
    "deploy:openshift:cluster": "./scripts/kube-apply.sh deploy/openshift/cluster/ && ./deploy/openshift/cluster/oauthclient.sh $ROUTE_HOSTNAME",
    "kustomize:image": "cd deploy/base && kustomize edit set image hawtio/online=quay.io/${ORG:-hawtio}/${PROJECT:-online}:${TAG:-latest}"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.38.0",
    "compression-webpack-plugin": "^11.1.0",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-testing-library": "^6.3.0",
    "prettier": "3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "webpack": "^5.105.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "maxLineWidth": 80
    }
  },
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "eslint-config-react-app>eslint-plugin-react-hooks": "^4.6.2"
  }
}
