###############################
#
# Node server settings
#
###############################

# Node environment
NODE_ENV=production

LOG_LEVEL=info

# Turn off TLS verify
NODE_TLS_REJECT_UNAUTHORIZED = 0

# Specify the cluster type
# Determined by gateway.sh entrypoint
HAWTIO_ONLINE_GATEWAY_CLUSTER_IS_OPENSHIFT=true

# Should a proxy certificate be required for comms with target apps
HAWTIO_ONLINE_GATEWAY_SSL_PROXY_KEY=''
HAWTIO_ONLINE_GATEWAY_SSL_PROXY_CERTIFICATE=''
